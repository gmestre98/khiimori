# Eudaimonia backend — local environment template.
#
# Copy this file to `.env` (which is gitignored) and fill in real values:
#
#     cp .env.example .env
#
# NEVER commit `.env` or paste a real connection string into a tracked file.
# In deployment these values come from GCP Secret Manager (wired in M01.4), not
# from a file.
#
# Every variable here is REQUIRED — the service fails fast at startup if any is
# unset (no silent defaults). Only the active DB DSN (per DB_POOLED) is needed;
# the other is optional.

# --- HTTP server -----------------------------------------------------------
PORT=8080
ENV=dev
LOG_LEVEL=error

# --- Database (Neon Postgres) ----------------------------------------------
# See backend/docs/database.md for how to obtain these from the Neon console.
#
# Neon exposes two endpoints for the same database. They differ only by the
# "-pooler" segment in the host:
#
#   pooled  -> ...-pooler.<region>.aws.neon.tech   (pgBouncer; app traffic)
#   direct  -> ...........<region>.aws.neon.tech   (no pooler; migrations/admin)

# Pooled (pgBouncer) endpoint — used by app traffic and the /readyz check.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxxxxxx-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require

# Direct endpoint — used by migrations and admin tasks (bypasses the pooler).
DATABASE_URL_DIRECT=postgresql://USER:PASSWORD@ep-xxxxxxxx.eu-west-2.aws.neon.tech/neondb?sslmode=require

# Route app traffic through the pooler (true) or the direct endpoint (false).
# Flipping this is a config change, not a code change (PRD §8.6).
DB_POOLED=true
