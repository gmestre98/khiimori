# Khiimori backend — local environment template.
#
# Copy this file to `.env` (which is gitignored) and fill in real values:
#
#     cp .env.example .env
#
# NEVER commit `.env` or paste a real connection string into a tracked file.
# In deployment these values come from GCP Secret Manager (wired in M01.4), not
# from a file.
#
# Every variable here is REQUIRED — the service fails fast at startup if any is
# unset (no silent defaults). Only the active DB DSN (per DB_POOLED) is needed;
# the other is optional.

# --- HTTP server -----------------------------------------------------------
PORT=8080
ENV=dev
LOG_LEVEL=error

# Cross-origin allowlist (optional) — comma-separated browser origins permitted
# to call the API. Matched exactly (no wildcard). Locally this is the Vite dev
# server origin; in deployment it's set to the Firebase Hosting origin (wired by
# infra, see infra/README.md). Leave unset to allow no cross-origin requests.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Database (Neon Postgres) ----------------------------------------------
# See backend/docs/database.md for how to obtain these from the Neon console.
#
# Neon exposes two endpoints for the same database. They differ only by the
# "-pooler" segment in the host:
#
#   pooled  -> ...-pooler.<region>.aws.neon.tech   (pgBouncer; app traffic)
#   direct  -> ...........<region>.aws.neon.tech   (no pooler; migrations/admin)

# Pooled (pgBouncer) endpoint — used by app traffic and the /readyz check.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxxxxxx-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require

# Direct endpoint — used by migrations and admin tasks (bypasses the pooler).
DATABASE_URL_DIRECT=postgresql://USER:PASSWORD@ep-xxxxxxxx.eu-west-2.aws.neon.tech/neondb?sslmode=require

# Route app traffic through the pooler (true) or the direct endpoint (false).
# Flipping this is a config change, not a code change (PRD §8.6).
DB_POOLED=true

# --- Google OAuth 2.0 / OIDC sign-in (M02.1) ----------------------------------
# Create a Web application OAuth 2.0 client in Google Cloud Console
# (APIs & Services → Credentials) and fill in the values below.
# In production these are injected from Secret Manager via Cloud Run env vars.
#
# Authorized redirect URI to register in Google Cloud Console (per environment):
#   dev:  http://localhost:8080/auth/callback
#   prod: https://<your-cloud-run-url>/auth/callback
OAUTH_CLIENT_ID=<your-client-id>.apps.googleusercontent.com
OAUTH_CLIENT_SECRET=<your-client-secret>
OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback

# --- Admin bootstrap (M02.2) --------------------------------------------------
# Optional. The verified Google email provisioned with is_admin=true, enabling
# Milestone 08's backoffice. Matched case-insensitively at sign-in; promote-only
# (a sign-in never revokes admin). Leave unset for no admin. See
# docs/admin-bootstrap.md.
# ADMIN_EMAIL=owner@example.com

# --- Sessions (M02.3) ---------------------------------------------------------
# HMAC signing key for authenticated session cookies. Required for sign-in to
# issue a session and for the auth middleware to validate one. In production this
# is injected from Secret Manager; locally, set a long random value, e.g.
#   openssl rand -base64 48
# Rotating it invalidates all existing sessions. See docs/sessions.md.
SESSION_SECRET=<long-random-string>
