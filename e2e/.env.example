# E2E environment contract (copy to e2e/.env for a local run against staging).
# .env is git-ignored; only this example is committed. No real secret goes here.
#
# Run locally:
#   cd e2e && npm ci && npm run install-browsers
#   E2E_WEB_URL=… E2E_API_URL=… E2E_LOGIN_SECRET=… npm test
# (or put the values in e2e/.env and export them yourself)

# Web app base URL (Firebase Hosting) — the browser loads this.
E2E_WEB_URL=https://khiimori-web.web.app

# API base URL (Cloud Run) — the auth setup posts /auth/test-login here.
E2E_API_URL=https://khiimori-api-xxxxxxxx-ew.a.run.app

# Shared secret for the guarded test-login endpoint (M10.1). MUST match the
# E2E_LOGIN_SECRET configured on the target API. Keep it out of git — supply it
# from CI secrets / Secret Manager. The value below is a placeholder.
E2E_LOGIN_SECRET=replace-with-the-staging-secret
