# Stack config template for the `dev` stack.
#
# Copy this to `Pulumi.dev.yaml` and fill in your values:
#
#     cp Pulumi.dev.yaml.example Pulumi.dev.yaml
#
# `Pulumi.dev.yaml` IS committed (un-ignored in .gitignore) because CI runs
# `pulumi up` and needs it — safe as long as secret values are Pulumi `secure:`
# blobs (encrypted) and there are no plaintext secrets. This `.example` is the
# annotated reference of the config surface; keep the two in sync when adding
# config. NEVER write a plaintext secret in either file.
config:
  # GCP project to deploy into (author-provided, billing enabled — PRD §8.3).
  # Read natively by the @pulumi/gcp provider; also surfaced as a typed value.
  gcp:project: your-gcp-project-id
  # GCP region. europe-west2 (London) pairs with the Neon DB in eu-west-2
  # (AWS London) for low cross-service latency — see backend/docs/database.md.
  gcp:region: europe-west2

  # --- Optional: resource names (sensible defaults if omitted) ---------------
  # Artifact Registry Docker repository id (last segment of the image prefix).
  # khiimori:artifactRepoId: khiimori
  # Cloud Storage media bucket name (globally unique; default <project>-media).
  # khiimori:mediaBucketName: your-project-media
  # Allow `pulumi destroy` to delete a non-empty media bucket (default false).
  # khiimori:mediaBucketForceDestroy: "false"
  # Cloud Run runtime service account id (6-30 chars; default khiimori-run).
  # khiimori:cloudRunServiceAccountId: khiimori-run
  # Cloud Run service name (default khiimori-api).
  # khiimori:serviceName: khiimori-api
  # Container image. Default is a public placeholder so a fresh stack stands up;
  # CI (M01.5) overrides with the real S2 image, e.g. <imagePrefix>/api:<sha>.
  # khiimori:serviceImage: europe-west2-docker.pkg.dev/your-project/khiimori/api:latest
  # Container port the app listens on (default 8080).
  # khiimori:servicePort: "8080"
  # Deployment env / log level the service runs with (default prod / error).
  # khiimori:serviceEnv: prod
  # khiimori:logLevel: error
  # Allow unauthenticated invocation so the browser SPA can call the API
  # (default true; set false to make the service private).
  # khiimori:allowUnauthenticated: "true"
  # Google OAuth sign-in (M02.1). Non-secret; the client *secret* is set as a
  # Pulumi secret (see below). Both must match the OAuth client in the Google
  # Cloud console; the redirect URI must be <cloudRunUrl>/auth/callback. Unset
  # → the app reports sign-in unconfigured (503).
  # khiimori:oauthClientId: <your-client-id>.apps.googleusercontent.com
  # khiimori:oauthRedirectUri: https://<cloud-run-url>/auth/callback
  # Admin-bootstrap email (M02.2 S4): the one verified Google email provisioned
  # as admin (gates the M08 admin backoffice). OR-promoted on sign-in; no
  # public/self-serve route. Non-secret. Unset → nobody is admin.
  # khiimori:adminEmail: your@email.com
  # Firebase project id (default: same as gcp:project). Firebase must already be
  # enabled on it — `firebase projects:addfirebase <project>` (one-time).
  # khiimori:firebaseProject: your-firebase-project-id
  # Firebase Hosting site id (globally unique, <=30 chars; default <project>-web).
  # khiimori:hostingSiteId: your-project-web
  # Cross-origin allowlist (M01.6 S3) — comma-separated browser origins allowed
  # to call the API. Default: the Firebase Hosting origin. Override to add more
  # (e.g. a custom domain — M01.6 S5): "https://app.example.com,https://...".
  # khiimori:corsAllowedOrigins: https://your-project-web.web.app

  # --- CI/CD keyless auth (M01.5 S5) -----------------------------------------
  # GitHub repo (owner/name) whose Actions may impersonate the deployer SA via
  # Workload Identity Federation. Default: gmestre98/khiimori.
  # khiimori:githubRepo: gmestre98/khiimori
  # CI/CD deployer service account id (6-30 chars; default khiimori-ci).
  # khiimori:ciDeployerServiceAccountId: khiimori-ci

  # --- Observability (M01.7 S4) — error alert recipient ----------------------
  # Email address that receives 5xx error alerts. Must be reachable on mobile
  # abroad (PRD §6). Default: the author's Gmail address. Not a secret.
  # khiimori:alertEmail: your@email.com

  # --- Cost guardrails (M01.8) -----------------------------------------------
  # GCP billing account the project is linked to (format: XXXXXX-XXXXXX-XXXXXX).
  # Find it: GCP Console → Billing → My billing accounts. Not a secret.
  # If unset, the billing budget is skipped (a warning fires at pulumi up).
  # khiimori:billingAccount: XXXXXX-XXXXXX-XXXXXX
  # Monthly budget amount in EUR (default: 10). The budget alerts at 50/90/100%;
  # it does not auto-cap spend — raise it when intentionally scaling up.
  # khiimori:billingBudgetEur: "10"

  # --- Scale tunables (S9) — defaults are the cheap, idle-≈€0 ones -----------
  # Cloud Run min instances. 0 = scale-to-zero (default). 1 keeps one warm 24/7
  # (no cold starts) and bills continuously — the single "scale up" toggle.
  # khiimori:minInstances: "0"
  # Cloud Run max instances (default 2). Caps concurrency + worst-case spend.
  # khiimori:maxInstances: "2"
  # Neon tier reference (default free). Lever: free -> paid in the Neon console.
  # khiimori:neonTier: free
  # Google Maps daily request quota reference (default 1000). Hard cap is M01.8.
  # khiimori:mapsDailyQuota: "1000"

  # --- Secret VALUES — never write them here in plaintext --------------------
  # The program creates the secret *containers*; their values are supplied
  # out-of-band. Two supported ways (pick one), both keep plaintext out of git:
  #
  #   a) Pulumi secret config (encrypted into the stack file, read by the
  #      program to create the first version):
  #        pulumi config set --secret khiimori:databaseUrl       "postgresql://app_rw:…"
  #        pulumi config set --secret khiimori:oauthClientSecret "…"
  #        pulumi config set --secret khiimori:mapsApiKey        "…"
  #        pulumi config set --secret khiimori:databaseUrlDirect "postgresql://neondb_owner:…"
  #        pulumi config set --secret khiimori:e2eLoginSecret    "…"  # M10.1 E2E test-login
  #      (e2eLoginSecret must MATCH the E2E_LOGIN_SECRET GitHub Actions secret;
  #       leave it unset to keep the guarded test-login endpoint disabled.)
  #      (These land here as `secure:` blobs — encrypted, safe to commit if you
  #       ever choose to track the stack file; this repo gitignores it anyway.)
  #
  #   b) Out-of-band after `pulumi up`, leaving config unset:
  #        gcloud secrets versions add khiimori-database-url --data-file=-
  #
  # The databaseUrl value MUST use the least-privilege Neon role `app_rw`
  # (not neondb_owner) — see backend/docs/database.md. databaseUrlDirect is the
  # OWNER DSN on the DIRECT endpoint, used only by CI to run migrations (S7).
